# ============================================================
# Answer mode — FREE options first
# ============================================================
# extractive = no API, show best PDF text (default, 100% free)
# ollama     = free local LLM (install https://ollama.com)
# gemini     = free Google API key (https://aistudio.google.com/apikey)
# xai        = Grok (needs PAID credits on https://console.x.ai)
#
# Streamlit Cloud: set the same keys in App → Settings → Secrets
# (see docs/DEPLOY.md). Env vars win over secrets when both exist.
RAG_LLM_PROVIDER=extractive

# --- Free: Google Gemini (optional) ---
# GEMINI_API_KEY=your_free_key_here
# Use 1.5-flash if 2.0-flash returns 429 / limit:0 on free tier
# GEMINI_MODEL=gemini-1.5-flash

# --- Free: Ollama local (optional) ---
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.2

# --- Paid: xAI Grok (optional) ---
# XAI_API_KEY=xai-...
# XAI_BASE_URL=https://api.x.ai/v1
# RAG_LLM_MODEL=grok-4.5

# --- Retrieval tuning ---
# RAG_TOP_K=3
# RAG_MAX_DISTANCE=1.05
